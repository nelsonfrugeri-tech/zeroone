{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "mcp/github-server", "python", "server.py"],
      "env": {
        "GITHUB_APP_ID": "<your-github-app-id>",
        "GITHUB_APP_PEM_PATH": "<path-to-your-pem-file>",
        "GITHUB_APP_INSTALLATION_ID": "<your-installation-id>",
        "GITHUB_APP_SLUG": "<your-app-slug>"
      }
    },
    "mem0": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "mcp/mem0-server", "python", "server.py"],
      "env": {
        "QDRANT_HOST": "localhost",
        "QDRANT_PORT": "6333",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "MEM0_COLLECTION": "claude-code-memory",
        "MEM0_USER_ID": "claude-code"
      }
    },
    "langfuse": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp-servers/langfuse/index.js"],
      "env": {
        "LANGFUSE_HOST": "http://localhost:3000",
        "LANGFUSE_PUBLIC_KEY": "<your-langfuse-public-key>",
        "LANGFUSE_SECRET_KEY": "<your-langfuse-secret-key>"
      }
    },
    "excalidraw": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "excalidraw-mcp"],
      "env": {}
    },
    "drawio": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "drawio-mcp"],
      "env": {}
    }
  }
}
