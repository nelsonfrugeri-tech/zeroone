{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "mem0": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "mcp/mem0-server", "python", "server.py"],
      "env": {
        "QDRANT_HOST": "localhost",
        "QDRANT_PORT": "6333",
        "OLLAMA_URL": "http://localhost:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "MEM0_COLLECTION": "claude-code-memory",
        "MEM0_USER_ID": "claude-code"
      }
    },
    "langfuse": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp-servers/langfuse/index.js"],
      "env": {
        "LANGFUSE_HOST": "http://localhost:3000",
        "LANGFUSE_PUBLIC_KEY": "${LANGFUSE_PUBLIC_KEY}",
        "LANGFUSE_SECRET_KEY": "${LANGFUSE_SECRET_KEY}"
      }
    },
    "excalidraw": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "excalidraw-mcp"],
      "env": {}
    },
    "drawio": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "drawio-mcp"],
      "env": {}
    }
  }
}
